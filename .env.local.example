# ─── Sanity CMS ───────────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage → your project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Set this to your custom domain once connected in Vercel
NEXT_PUBLIC_SITE_URL=https://dmgraphix.com

# ─── Contact form (optional) ──────────────────────────────────────────────────
# Add Resend or similar for email delivery from the contact form
# RESEND_API_KEY=your_resend_key
# CONTACT_EMAIL=hello@dmgraphix.com

# ─── Notes ────────────────────────────────────────────────────────────────────
# For Vercel deployment, add all these variables in:
# Vercel Dashboard → Project → Settings → Environment Variables
# NEXT_PUBLIC_ prefixed vars are safe to expose to the browser.
# All others (API keys) are server-only — never prefix them with NEXT_PUBLIC_.
